# Browser-safe values (copy into docs/js/config.js for GitHub Pages deployment)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME
CLAN_SLUG=insomnia

# Server-side migration/backup only. Never put this key under docs/ or commit it.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_REPLACE_ME
CLAN_MEMBER_PASSWORD=replace-me
CLAN_ADMIN_PASSWORD=replace-me
